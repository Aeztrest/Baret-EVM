{
  "name": "@baret/guard",
  "version": "0.1.0",
  "description": "Baret pre-sign transaction guard SDK for EVM (chain-light, no ethers required to consume).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": ["evm", "ethereum", "wallet", "security", "transaction", "firewall", "x402", "baret"],
  "homepage": "https://baret.example",
  "repository": { "type": "git", "url": "git+https://github.com/Aeztrest/Baret-EVM.git", "directory": "packages/guard" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
