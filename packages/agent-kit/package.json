{
  "name": "@baret/agent-kit",
  "version": "0.1.0",
  "description": "Guard your agent / program wallet with Baret: a drop-in ethers signer + CLI that runs every transaction through Baret's pre-sign firewall and refuses to sign what your policy blocks.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "bin": {
    "baret": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "keywords": ["evm", "ethereum", "agent", "ai-agent", "wallet", "security", "ethers", "signer", "baret"],
  "homepage": "https://baret.example/agents",
  "repository": { "type": "git", "url": "git+https://github.com/Aeztrest/Baret-EVM.git", "directory": "packages/agent-kit" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@baret/guard": "workspace:*",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
