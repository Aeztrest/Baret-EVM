# ── Premon server configuration ──

# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Target EVM chain — every value below is overridable to point at any EVM chain.
NETWORK=testnet                       # testnet | mainnet
RPC_URL=https://testnet-rpc.monad.xyz # JSON-RPC endpoint (required)
# CHAIN_ID=10143                       # optional override (default per network)
# EXPLORER_URL=https://...             # optional block explorer override
# NATIVE_SYMBOL=ETH                    # optional native gas token symbol override
# NATIVE_DECIMALS=18                   # optional native gas token decimals override

# USDC token used for x402 + min-balance defaults.
# IMPORTANT: the bundled default is a PLACEHOLDER. Set this to the real USDC
# contract on your target chain before relying on token metadata / x402.
# USDC_ADDRESS=0x...
USDC_DECIMALS=6

# Reputation / allowlists (comma-separated 0x addresses)
# RISKY_CONTRACT_IDS=0x...
# KNOWN_SAFE_CONTRACT_IDS=0x...

# Auth
# DELTAG_API_KEYS=key1,key2                  # empty = open (dev only)
# DELTAG_AUTH_MODE=api_key                   # api_key | x402 | both

# Limits
MAX_SIMULATION_OPERATIONS=20
REQUEST_TIMEOUT_MS=25000
DELTAG_RATE_LIMIT_MAX=200
DELTAG_RATE_LIMIT_WINDOW_MS=60000
# DELTAG_TRUST_PROXY=1

# x402 (optional)
# X402_ENABLED=true
# X402_PAY_TO=0x...                          # required when x402 enabled
# X402_FACILITATOR_URL=https://www.x402.org/facilitator
# X402_NETWORK=eip155:10143
# X402_ANALYZE_PRICE=$0.001

# NovaSwap demo vault (optional) — showcase's NovaSwap site has no real DEX
# liquidity, so this EOA stands in for a pool: pay it MON/USDC, it pays back
# the counterpart at a fixed rate. Unset => the feature is inert (frontend
# falls back to a self-transfer-only demo). Fund this address with testnet
# MON + USDC before enabling. Never commit the private key.
# NOVASWAP_VAULT_PRIVATE_KEY=0x...
# NOVASWAP_MON_USDC_RATE=4                   # 1 MON = this many USDC (integer)
# NOVASWAP_MAX_MON_PER_SWAP=5                # safety cap, MON-equivalent per swap
